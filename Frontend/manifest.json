{
    "manifest_version": 3,
    "name": "Time Tracker Extension",
    "version": "1.0",
    "description": "Track time you spend on every website",
    "permissions": [
        "tabs",
        "storage",
        "activeTab",
        "alarms",
        "windows"
    ],
    "host_permissions": [
        "https://time-tracker-extension-jc74.onrender.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "48": "icons/icon48.png"
        }
    }
}